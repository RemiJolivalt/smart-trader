# ============================================================
# Smart Trader — Frontend environment variables
# Copier ce fichier en .env.local et renseigner les valeurs.
# Ne JAMAIS commiter .env.local (déjà dans .gitignore).
# ============================================================

# --- Supabase ---
# Projet Supabase (dev ou prod selon l'environnement)
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>

# --- Sentry ---
# DSN du projet Sentry frontend (Next.js)
NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# --- App ---
# URL publique de l'API backend (ex: https://api.smart-trader.fly.dev)
NEXT_PUBLIC_API_URL=http://localhost:8000
