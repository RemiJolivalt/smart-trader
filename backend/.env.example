# ============================================================
# Smart Trader — Backend environment variables
# Copier ce fichier en .env et renseigner les valeurs.
# Ne JAMAIS commiter .env (déjà dans .gitignore).
# ============================================================

# --- Supabase ---
# URL et clé service_role (accès complet DB, côté backend uniquement)
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# --- IBKR (Interactive Brokers) ---
# Identifiants broker — stocker chiffrés en DB, pas ici en prod
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
# Clé de chiffrement AES-GCM pour les API keys IBKR stockées en DB
IBKR_ENCRYPTION_KEY=<base64-encoded-32-byte-key>

# --- Notifications ---
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
TELEGRAM_CHAT_ID=<telegram-chat-id>

# SMTP (alertes email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=<smtp-user>
SMTP_PASSWORD=<smtp-password>
SMTP_FROM=alerts@smart-trader.local

# --- Sentry ---
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# --- App ---
ENVIRONMENT=development
# Secret pour signer les tokens JWT (min 32 caractères)
SECRET_KEY=<change-me-min-32-chars>
LOG_LEVEL=INFO
